datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Profile {
  id        String   @id           // Supabase auth user UUID
  username  String   @default("Anonymous")
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments      Comment[]
  commentVotes  CommentVote[]
  votes         Vote[]
  voteHistory   VoteHistory[]
  conversations Conversation[]
  donations     Donation[]

  @@index([username])
}

model Bill {
  id                Int                  @id @default(autoincrement())
  billId            String               @unique
  title             String
  date              DateTime
  billType          String
  currentChamber    String?
  currentStatus     String
  currentStatusDate DateTime
  introducedDate    DateTime
  link              String
  shortText         String?
  fullText          String?
  sponsor             String?
  cosponsorCount      Int?
  cosponsorPartySplit String?
  policyArea          String?
  latestActionText    String?
  latestActionDate    DateTime?
  // Momentum signal — computed daily by compute-momentum.
  // Tier: DEAD | DORMANT | STALLED | ACTIVE | ADVANCING | ENACTED
  // deathReason: CONGRESS_ENDED | FAILED_VOTE | VETOED | LONG_SILENCE | null
  congressNumber      Int?
  momentumScore       Int?
  momentumTier        String?
  daysSinceLastAction Int?
  deathReason         String?
  momentumComputedAt  DateTime?
  // Set whenever refresh-bill-metadata successfully calls Congress.gov.
  // Used to avoid re-fetching bills whose CRS summary hasn't been
  // published yet — without it the cron loops over ~12k bills forever.
  lastMetadataRefreshAt DateTime?
  // Set whenever fetch-bill-text runs against a bill (success OR failure).
  // The text backfill cron orders by this ascending NULLS FIRST so bills we
  // can't get text for (genuinely unpublished, withdrawn, etc.) rotate to
  // the back of the queue instead of blocking all other bills behind them.
  textFetchAttemptedAt DateTime?
  // Title variants fetched from Congress.gov /titles endpoint. We search
  // on all of these via the weighted searchVector generated column —
  // users type popular names ("CHIPS Act"), not official titles.
  popularTitle      String?
  shortTitle        String?
  displayTitle      String?
  searchVector      Unsupported("tsvector")?
  votes             RepresentativeVote[]
  publicVotes       Vote[]
  comments          Comment[]
  conversations     Conversation[]
  actions           BillAction[]
  textVersions      BillTextVersion[]
  voteHistory       VoteHistory[]
  cosponsors        BillCosponsor[]

  @@index([momentumTier, momentumScore(sort: Desc)])
  @@index([congressNumber])
  // Partial index on textFetchAttemptedAt (WHERE fullText IS NULL) lives in
  // the 20260418150000 migration — Prisma schema can't express partial
  // indexes, and a full-table index would waste space on the bills that
  // already have text.
}

model BillCosponsor {
  id               Int       @id @default(autoincrement())
  billId           Int
  representativeId Int
  sponsoredAt      DateTime?
  isOriginal       Boolean   @default(false)
  withdrawnAt      DateTime?

  bill           Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  representative Representative @relation(fields: [representativeId], references: [id])

  @@unique([billId, representativeId])
  @@index([billId])
  @@index([representativeId])
}

model BillAction {
  id          Int      @id @default(autoincrement())
  billId      Int
  actionDate  DateTime
  chamber     String?
  text        String
  actionType  String?

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@unique([billId, actionDate, text])
  @@index([billId])
}

model Representative {
  id        Int                  @id @default(autoincrement())
  bioguideId String              @unique
  slug      String?              @unique
  firstName String
  lastName  String
  state     String
  district  String?
  party     String
  chamber   String
  imageUrl  String?
  link      String?
  phone     String?
  votes     RepresentativeVote[]
  cosponsorships BillCosponsor[]
}

model RepresentativeVote {
  id               Int            @id @default(autoincrement())
  representativeId Int
  billId           Int
  vote             String
  rollCallNumber   Int?
  chamber          String?
  votedAt          DateTime?
  category         String?

  representative Representative @relation(fields: [representativeId], references: [id])
  bill           Bill           @relation(fields: [billId], references: [id])

  @@unique([representativeId, billId, rollCallNumber])
  @@index([billId, chamber])
  @@index([billId, rollCallNumber])
}

model BillTextVersion {
  id            Int      @id @default(autoincrement())
  billId        Int
  versionCode   String
  versionType   String
  versionDate   DateTime
  fullText      String?
  isSubstantive Boolean  @default(true)
  changeSummary String?
  // AI-generated one-sentence captions for each parsed section, used by
  // the bill reader's smart outline. Stored as [{ sectionId, caption }]
  // aligned to the slugs produced by sectionSlugsForBill(...). Null means
  // "not yet generated for this version" — the reader degrades gracefully.
  sectionCaptions   Json?
  captionsModel     String?
  captionsCreatedAt DateTime?
  createdAt     DateTime @default(now())

  bill        Bill          @relation(fields: [billId], references: [id])
  activeVotes Vote[]
  voteHistory VoteHistory[]

  @@unique([billId, versionCode])
  @@index([billId])
}

model Vote {
  id            Int      @id @default(autoincrement())
  userId        String
  billId        Int
  voteType      String
  textVersionId Int?
  votedAt       DateTime @default(now())

  profile     Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill        Bill             @relation(fields: [billId], references: [id], onDelete: Cascade)
  textVersion BillTextVersion? @relation(fields: [textVersionId], references: [id])

  @@unique([userId, billId])
  @@index([userId])
}

model VoteHistory {
  id            Int      @id @default(autoincrement())
  userId        String
  billId        Int
  voteType      String
  textVersionId Int?
  createdAt     DateTime @default(now())

  profile     Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill        Bill             @relation(fields: [billId], references: [id], onDelete: Cascade)
  textVersion BillTextVersion? @relation(fields: [textVersionId], references: [id])

  @@index([userId, billId])
  @@index([billId])
}

model Comment {
  id              Int           @id @default(autoincrement())
  content         String
  userId          String?
  username        String        @default("Anonymous")
  billId          Int
  parentCommentId Int?
  date            DateTime      @default(now())

  profile       Profile?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  bill          Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  parentComment Comment?       @relation("CommentToReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentToReplies")
  commentVotes  CommentVote[]

  @@index([userId])
  @@index([billId])
  @@index([billId, parentCommentId])
}

model CommentVote {
  id        Int    @id @default(autoincrement())
  userId    String
  commentId Int
  voteType  Int

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  billId    Int
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([userId, billId])
  @@index([billId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String
  text           String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// ============================================================================
// Donations, budget, and AI cost guardrails
// ============================================================================

enum DonationDisplayMode {
  ANONYMOUS
  NAMED
  TRIBUTE
}

enum DonationModStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
}

enum RecurringStatus {
  ACTIVE
  GRACE
  LAPSED
  CANCELED
}

model Donation {
  id               String               @id @default(cuid())
  // Stripe identifiers. For one-time: PaymentIntent id. For recurring: Subscription id.
  stripePaymentId  String               @unique
  stripeCustomerId String?
  // Supabase auth user id — nullable because logged-out donations are allowed.
  userId           String?
  amountCents      Int
  currency         String               @default("usd")
  isRecurring      Boolean              @default(false)
  recurringStatus  RecurringStatus?
  displayMode      DonationDisplayMode  @default(ANONYMOUS)
  displayName      String?              // post-moderation, safe to show publicly
  displayNameRaw   String?              // pre-moderation, audit trail only
  tributeName      String?              // post-moderation
  tributeNameRaw   String?              // pre-moderation
  moderationStatus DonationModStatus    @default(PENDING)
  moderationNotes  String?
  regionCode       String?              // state-level only (e.g. "US-OH") from Stripe billing
  email            String?              // for receipt + linking token
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  hiddenAt         DateTime?            // user-requested removal from public page (soft)

  profile          Profile?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  linkToken        DonorLinkToken?

  @@index([createdAt])
  @@index([userId])
  @@index([isRecurring, recurringStatus])
  @@index([moderationStatus])
}

model DonorLinkToken {
  id         String    @id @default(cuid())
  donationId String    @unique
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  donation   Donation  @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([token])
}

model BudgetLedger {
  id              String   @id @default(cuid())
  // YYYY-MM identifier for the budget period. One row per month.
  period          String   @unique
  incomeCents     Int      @default(0)
  spendCents      Int      @default(0)
  // Reserve withheld from "available" before flipping AI on.
  reserveCents    Int      @default(0)
  aiEnabled       Boolean  @default(true)
  // Reason the current aiEnabled value was set. "budget" | "manual" | "bootstrap"
  aiDisabledReason String?
  lastEvaluated   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AiUsageEvent {
  id           String   @id @default(cuid())
  userId       String?
  // Logical feature name, e.g. "chat" | "bill_summary" | "section_explain" | "moderation"
  feature      String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costCents    Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([feature, createdAt])
}

model AiResponseCache {
  id         String   @id @default(cuid())
  billId     Int
  promptHash String
  response   String
  model      String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@unique([billId, promptHash])
  @@index([expiresAt])
}

model AdminUser {
  id        String   @id @default(cuid())
  // Supabase auth user id (uuid)
  userId    String   @unique
  email     String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// Congress session status — "is Congress working right now?" indicator
// ============================================================================

// Live per-chamber status, recomputed every ~10 minutes by the
// compute-congress-status cron. One row per chamber, upserted.
//
// status values:
//   voting              — chamber is on the floor and voted recently
//   in_session          — chamber gaveled in with floor activity
//   pro_forma           — brief procedural session with no legislative business
//   recess              — scheduled non-session period
//   adjourned_sine_die  — formal end of session (between Congresses)
//   unknown             — no signal resolved; render a neutral pill
//
// source is whichever signal in the waterfall produced this status:
//   clerk_xml | senate_pail | vote_recency | calendar | none
model CongressChamberStatus {
  chamber             String    @id // "house" | "senate"
  status              String
  detail              String? // short human label — e.g. "Roll call vote 18 min ago"
  source              String
  lastActionAt        DateTime? // timestamp from the source signal itself
  nextTransitionAt    DateTime? // next scheduled transition start (recess begin / session resume)
  nextTransitionLabel String? // "Memorial Day District Work Period", "Returns Apr 28", etc.
  lastCheckedAt       DateTime  @default(now()) // when the cron last ran the waterfall
  updatedAt           DateTime  @updatedAt
}

// Published non-session periods, seeded per-year from the official
// House Majority Leader and Senate calendars. Used as the fallback
// tier in the waterfall when no live signal is present today.
model CongressRecess {
  id        String   @id @default(cuid())
  chamber   String // "house" | "senate"
  startDate DateTime @db.Date
  endDate   DateTime @db.Date // inclusive
  label     String

  @@index([chamber, startDate, endDate])
}
