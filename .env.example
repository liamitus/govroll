# =============================================================================
# Govroll Environment Variables
# Copy this file to .env and fill in real values:  cp .env.example .env
# =============================================================================

# --- Database ----------------------------------------------------------------
# Local dev: use docker compose up -d to start Postgres on port 5434
# Production: Supabase pooled connection string from your project dashboard
DATABASE_URL="postgresql://govroll:govroll@localhost:5434/govroll_dev"

# --- Supabase ----------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Google OAuth (Sign in with Google) -------------------------------------
# Web OAuth client ID used by Google Identity Services (browser-side flow).
# Same client ID as the one configured in Supabase Auth → Providers → Google.
# Console: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include: http://localhost:1776,
# https://govroll.com, https://www.govroll.com (plus any preview domains).
# When set, the auth modal uses Google Identity Services to fetch an ID token
# directly in the browser and signs in via supabase.auth.signInWithIdToken,
# skipping the supabase.co OAuth redirect (and its sketchy-looking domain) that
# the legacy signInWithOAuth flow triggers.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="123-abc.apps.googleusercontent.com"

# --- Anthropic (bill chat) ---------------------------------------------------
# Direct Anthropic API key. Powers the bill chat, explain-passage popover,
# and section captions via @ai-sdk/anthropic. Per-call usage is recorded in
# the local spend ledger; observability via console.anthropic.com.
# Create a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# --- OpenAI (free moderation endpoint) ---------------------------------------
# Used only for the free /moderations endpoint (donor names, comments).
# Create a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# --- External APIs -----------------------------------------------------------
# Geocodio (address → congressional district): https://dash.geocod.io/apikey
# Free tier covers 2,500 lookups/day; we fall back to the free US Census
# geocoder if this key is missing, but coverage degrades for PO Boxes,
# at-large states, and some NYC-borough hyphenated house numbers.
GEOCODIO_API_KEY="your-geocodio-key"

# Congress.gov (bill text, actions): https://api.congress.gov/sign-up/
CONGRESS_DOT_GOV_API_KEY="your-congress-api-key"

# --- Admin & Cron ------------------------------------------------------------
# ADMIN_API_KEY: required for /api/admin endpoints. Generate a strong secret.
ADMIN_API_KEY="generate-a-strong-random-secret"

# CRON_SECRET: Vercel sends this in the Authorization header for cron jobs.
# Set the same value in Vercel project settings.
CRON_SECRET="generate-a-strong-random-secret"

# --- Stripe (Donations) -----------------------------------------------------
# Use test keys for local dev: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Error Alerting (optional) -----------------------------------------------
# Resend free tier: 100 emails/day. Sign up at https://resend.com
# Alerts are deduped (5-min window) and rate-limited (10/hour).
RESEND_API_KEY=""
ALERT_EMAIL="you@example.com"
# Requires a verified domain on Resend. Default uses Resend's onboarding sender.
# ALERT_FROM_EMAIL="Govroll Alerts <alerts@govroll.com>"
